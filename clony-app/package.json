{
  "name": "clony-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:offline": "EXPO_OFFLINE=1 expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:offline": "EXPO_OFFLINE=1 expo start --ios -c",
    "web": "expo start --web",
    "web:tailwind": "npx tailwindcss -i ./global.css -o ./output.css --watch",
    "dev": "concurrently \"npm run web:tailwind\" \"expo start --web\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-plugin-react-native-web": "^0.21.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-crypto": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.13",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.15.0",
    "tailwindcss": "^3.3.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.2"
  },
  "private": true
}